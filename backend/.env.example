# Application
APP_NAME=Website scrapper 
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ---------------------------------------------------------------------------
# Database — use YOUR local MySQL (recommended) OR Docker MySQL (optional)
# ---------------------------------------------------------------------------
#
# Option A (recommended): separate parameters — fill in your local MySQL details
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=leadforge
#
# Option B: full URL override (takes priority over DB_* if set)
# DATABASE_URL=mysql+asyncmy://user:password@127.0.0.1:3306/leadforge
#
# Create the database first, e.g. in MySQL:
#   CREATE DATABASE leadforge CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#
# Docker MySQL (optional, from project root: docker compose up -d) uses port 3307:
#   DB_PORT=3307
#   DB_USER=leadforge
#   DB_PASSWORD=leadforge

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Scraper — delays use jitter to look less robotic (see app/scraper/rate_limit.py)
SCRAPER_HEADLESS=true
SCRAPER_MAX_RESULTS=120
SCRAPER_SCROLL_PAUSE_MS=1500
SCRAPER_SCROLL_PAUSE_JITTER_MS=800
SCRAPER_REQUEST_DELAY_MS=800
SCRAPER_REQUEST_DELAY_JITTER_MS=600
SCRAPER_PAGE_SETTLE_MS=2000
SCRAPER_PAGE_SETTLE_JITTER_MS=1200
SCRAPER_PLACE_DETAILS_SETTLE_MS=2000
SCRAPER_WEBSITE_EXTRACT_RETRIES=4
SCRAPER_WEBSITE_RETRY_DELAY_MS=700
SCRAPER_SCROLL_STABLE_ROUNDS=5

# Bulk scraping (nationwide campaigns)
BULK_TARGET_DEFAULT=10000
BULK_DELAY_BETWEEN_SEARCHES_SECONDS=6
BULK_DELAY_JITTER_SECONDS=4
BULK_FAILURE_COOLDOWN_SECONDS=30
BULK_FAILURE_COOLDOWN_MAX_SECONDS=300
BULK_MAX_CONSECUTIVE_FAILURES=3
BULK_BLOCKED_COOLDOWN_SECONDS=600

# Website detection
WEBSITE_DETECTION_TIMEOUT_SECONDS=8
WEBSITE_DETECTION_CONCURRENCY=10
